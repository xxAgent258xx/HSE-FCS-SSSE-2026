	РаспределенияРаспределениеПриИзмененииНаСервере();
КонецПроцедуры
&НаКлиенте
Процедура ДобавитьУчастника(Команда)

    Если ПустаяСтрока(ВводимыйУчастник) Тогда
        ПоказатьПредупреждение(, "Введите ФИО участника");
        Возврат;
    КонецЕсли;

    // Вызываем серверную функцию поиска
    РезультатПоиска = НайтиПользователейПоФИОНаСервере(ВводимыйУчастник);

    Если РезультатПоиска.Количество() = 0 Тогда
        ПоказатьПредупреждение(, "Пользователь с таким ФИО не найден");
        ВводимыйУчастник = "";
        Возврат;
    ИначеЕсли РезультатПоиска.Количество() = 1 Тогда
        // Добавляем единственного найденного
        ДобавитьПользователяВМероприятиеНаСервере(РезультатПоиска[0].Ссылка);
        ВводимыйУчастник = "";
        Элементы.СписокУчастников.Обновить();
    Иначе
        // Несколько пользователей – показываем диалог выбора
        СписокВыбора = Новый СписокЗначений;
        Для Каждого Элемент Из РезультатПоиска Цикл
            СтрокаПредставления = Элемент.Наименование;
            Если ЗначениеЗаполнено(Элемент.Логин) Тогда
                СтрокаПредставления = СтрокаПредставления + " (логин: " + Элемент.Логин + ")";
            КонецЕсли;
            СписокВыбора.Добавить(Элемент.Ссылка, СтрокаПредставления);
        КонецЦикла;

        // Показываем диалог выбора (неблокирующий)
        ОповещениеОВыборе = Новый ОписаниеОповещения("ВыборУчастникаИзСпискаЗавершение", ЭтотОбъект);
        ПоказатьВыборИзСписка(ОповещениеОВыборе, СписокВыбора, , "Выберите участника");
    КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВыборУчастникаИзСпискаЗавершение(Результат, ДопПараметры) Экспорт
    Если Результат <> Неопределено Тогда
        ДобавитьПользователяВМероприятиеНаСервере(Результат);
        ВводимыйУчастник = "";
        Элементы.СписокУчастников.Обновить();
    Иначе
        // Пользователь отменил выбор – ничего не делаем
    КонецЕсли;
КонецПроцедуры


