	Возврат Ответ;
КонецФункции

Функция ПользовательНайден(СтрокаJSON)Экспорт
	
	 ЧтениеJSON = Новый ЧтениеJSON();
	 ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	 
	 НоменклатураМассив = ПрочитатьJSON(ЧтениеJSON);
	 Для Каждого СтрокаМассива Из НоменклатураМассив Цикл
	 	Логин = Справочники.Пользователи.НайтиПоРеквизиту("Логин", СтрокаМассива.Логин); 
	 	Если Логин.Пустая() Тогда
			СоздатьНоменклатуру(СтрокаМассива);
			Возврат Ложь;
	 	Иначе
	 		Возврат Истина;
	 	КонецЕсли
	 КонецЦикла;

 КонецФункции
 
 Процедура СоздатьНоменклатуру(СтруктураСДанными)
	 
	НоменклатураОбъект = Справочники.Пользователи.СоздатьЭлемент();
	НоменклатураОбъект.Наименование = СтруктураСДанными.Наименование;
	НоменклатураОбъект.Логин = СтруктураСДанными.Логин;
	НоменклатураОбъект.НомерТелефона = СтруктураСДанными.НомерТелефона;
	НоменклатураОбъект.Пароль = СтруктураСДанными.Пароль;
	НоменклатураОбъект.ТипАккаунта = Перечисления.ТипыАккаунтов.Участник;
	
	НоменклатураОбъект.Записать();
	 
 КонецПроцедуры

Функция РегистрацияPOST(Запрос)
	
	СтрокаНоменклатураJSON = Запрос.ПолучитьТелоКакСтроку();
	ПользовательНайден = ПользовательНайден(СтрокаНоменклатураJSON);
	Если ПользовательНайден Тогда
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.УстановитьТелоИзСтроки("Такой пользователь уже существует");
	Иначе
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.УстановитьТелоИзСтроки("Пользователь успешно зарегистрирован");
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

Функция ВходPOST(Запрос)

	СтрокаJSON = Запрос.ПолучитьТелоКакСтроку();
	
	// Читаем массив (как и в регистрации)
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	МассивДанных = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	Если МассивДанных.Количество() = 0 Тогда
		Ответ = Новый HTTPСервисОтвет(400);
		Ответ.УстановитьТелоИзСтроки("Не переданы данные для входа");
		Возврат Ответ;
	КонецЕсли;
	
	ДанныеВхода = МассивДанных[0];
	Логин = ДанныеВхода.Логин;
	Пароль = ДанныеВхода.Пароль;
	
	// Поиск пользователя по логину
	НайденныйПользователь = Справочники.Пользователи.НайтиПоРеквизиту("Логин", Логин);
	Если НайденныйПользователь.Пустая() Тогда
		Ответ = Новый HTTPСервисОтвет(400);
		Ответ.УстановитьТелоИзСтроки("Пользователь с таким логином не найден");
		Возврат Ответ;
	КонецЕсли;
	
	// Сравнение паролей (предполагаем, что пароль хранится в реквизите "Пароль")
	Если НайденныйПользователь.Пароль <> Пароль Тогда
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.УстановитьТелоИзСтроки("Неверный пароль");
		Возврат Ответ;
	КонецЕсли;
	
	// Всё верно
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.УстановитьТелоИзСтроки("Вход выполнен успешно");
	Возврат Ответ;
	
КонецФункции

Функция ЛичныеМероприятияGET(Запрос)

	// 1. Получаем логин из параметра URL
	Логин = Запрос.ПараметрыURL.Получить("login");
	
	Если ПустаяСтрока(Логин) Тогда
		Ответ = Новый HTTPСервисОтвет(400);
		Ответ.УстановитьТелоИзСтроки("Не указан логин пользователя");
		Возврат Ответ;
	КонецЕсли;
	
	// 2. Проверяем существование пользователя
	Пользователь = Справочники.Пользователи.НайтиПоРеквизиту("Логин", Логин);
	Если Пользователь.Пустая() Тогда
		Ответ = Новый HTTPСервисОтвет(404);
		Ответ.УстановитьТелоИзСтроки("Пользователь не найден");
		Возврат Ответ;
	КонецЕсли;
	
	// 3. Запрос к справочнику Мероприятия с фильтром по участнику
	ЗапросСУБД = Новый Запрос;
	ЗапросСУБД.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Мероприятия.Ссылка КАК Ссылка,
	|	Мероприятия.Код КАК Код,
	|	Мероприятия.Наименование КАК Наименование,
	|	Мероприятия.ЧислоУчастников КАК ЧислоУчастников,
	|	Мероприятия.ГлавныйОрганизатор.Наименование КАК ГлавныйОрганизатор,
	|	Мероприятия.Организация.Наименование КАК Организация,
	|	Мероприятия.Статус КАК Статус
	|ИЗ
	|	Справочник.Мероприятия КАК Мероприятия
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Мероприятия.СписокУчастников КАК СписокУчастников
	|		ПО Мероприятия.Ссылка = СписокУчастников.Ссылка
	|ГДЕ
	|	СписокУчастников.Логин = &Логин";
	
	ЗапросСУБД.УстановитьПараметр("Логин", Логин);
	
	Результат = ЗапросСУБД.Выполнить();
	Выборка = Результат.Выбрать();
	
	МассивМероприятий = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		СтруктураМероприятия = Новый Структура;
		СтруктураМероприятия.Вставить("Код", Выборка.Код);
		СтруктураМероприятия.Вставить("Наименование", Выборка.Наименование);
		СтруктураМероприятия.Вставить("ЧислоУчастников", Выборка.ЧислоУчастников);
		СтруктураМероприятия.Вставить("ГлавныйОрганизатор", Выборка.ГлавныйОрганизатор);
		СтруктураМероприятия.Вставить("Организация", Выборка.Организация);
		СтруктураМероприятия.Вставить("Статус", Выборка.Статус);
		
		МассивМероприятий.Добавить(СтруктураМероприятия);
	КонецЦикла;
	
	// 4. Преобразуем в JSON
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, МассивМероприятий);
	СтрокаJSON = ЗаписьJSON.Закрыть();
	
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(СтрокаJSON);
	
	Возврат Ответ;
	
КонецФункции


