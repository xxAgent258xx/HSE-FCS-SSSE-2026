
&НаСервере
Процедура СписокУчастниковПриИзмененииНаСервере()
	Элементы.СписокУчастников.КоманднаяПанель.Видимость = Объект.СписокУчастников.Количество() < Объект.ЧислоУчастников;
КонецПроцедуры

&НаКлиенте
Процедура СписокУчастниковПриИзменении(Элемент)
	СписокУчастниковПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПланировкаПриОкончанииРедактированияНаСервере(Начало, Конец, Значение, Аудитория, ПланИнд)
	НовСтрока = Истина;
	Для Инд = 0 По Объект.Распределения.Количество() - 1 Цикл
	
		Данные = Объект.Распределения[Инд];
		Если ЗначениеЗаполнено(Данные.Аудитория) И ЗначениеЗаполнено(Данные.ВремяНачала) И ЗначениеЗаполнено(Данные.ВремяОкончания) И ЗначениеЗаполнено(Данные.Распределение) Тогда 

//			// Если изменилось распределение
//			Если Начало = Данные.ВремяНачала И Конец = Данные.ВремяОкончания И Аудитория = Данные.Аудитория Тогда	
//				Данные.Распределение = Значение;
//				НовСтрока = Ложь;
//			
//			// Если изменилась аудитория			
//			ИначеЕсли Начало = Данные.ВремяНачала И Конец = Данные.ВремяОкончания И Значение = Данные.Распределение Тогда
//				Данные.Аудитория = Аудитория;
//				НовСтрока = Ложь;
			
			// Если изменилось время
			Если (НачалоДня(Начало) = НачалоДня(Данные.ВремяНачала) ИЛИ НачалоДня(Конец) = НачалоДня(Данные.ВремяОкончания)) И Значение = Данные.Распределение И Аудитория = Данные.Аудитория Тогда	
				Данные.ВремяНачала = Начало;
				Данные.ВремяОкончания = Конец;
				НовСтрока = Ложь;
			КонецЕсли;
			
			Если НовСтрока Тогда
			
				Запись = Объект.Распределения.Добавить();
				Запись.ВремяНачала = Начало;
				Запись.ВремяОкончания = Конец;
				Запись.Аудитория = Аудитория;
				Запись.Распределение = Значение;
				НовСтрока = Ложь;
							
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;		
КонецПроцедуры

&НаКлиенте
Процедура ПланировкаПриОкончанииРедактирования(Элемент, НовыйЭлемент, ОтменаРедактирования)
	Для Каждого Эл ИЗ Элемент.ВыделенныеЭлементы Цикл 
		Эл.Значение = Эл.Текст;
		Если ЗначениеЗаполнено(Эл.Начало) И ЗначениеЗаполнено(Эл.Конец) И ЗначениеЗаполнено(Эл.Значение) И ЗначениеЗаполнено(Эл.ЗначенияИзмерений["Аудитории"]) Тогда
			ПланировкаПриОкончанииРедактированияНаСервере(Эл.Начало, Эл.Конец, Эл.Значение, Эл.ЗначенияИзмерений["Аудитории"], Планировка.Элементы.Индекс(Эл));
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПланировкаПередУдалениемНаСервере(Начало, Конец, Значение, Аудитория)
	Для ТаблИнд = 0 По Объект.Распределения.Количество() - 1 Цикл
		Данные = Объект.Распределения[ТаблИнд];
		Если ЗначениеЗаполнено(Данные.Аудитория) И ЗначениеЗаполнено(Данные.ВремяНачала) И ЗначениеЗаполнено(Данные.ВремяОкончания) И ЗначениеЗаполнено(Данные.Распределение) Тогда
			Если Начало = Данные.ВремяНачала И Конец = Данные.ВремяОкончания И Значение = Данные.Распределение И Аудитория = Данные.Аудитория Тогда
				Объект.Распределения.Удалить(ТаблИнд);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПланировкаПередУдалением(Элемент, Отказ)
	Элы = Элемент.ВыделенныеЭлементы;
	Для ПланИнд = 0 ПО Элы.Количество() - 1 Цикл
		Эл = Элы[ПланИнд];
		ПланировкаПередУдалениемНаСервере(Эл.Начало, Эл.Конец, Эл.Значение, Эл.ЗначенияИзмерений["Аудитории"]);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура РаспределенияПередУдалениемНаСервере(Инд)
	Попытка
		Данные = Объект.Распределения[Инд];
		
		Для ПланИнд = 0 По Планировка.Элементы.Количество() - 1 Цикл
			Эл = Планировка.Элементы[ПланИнд];
			Если Эл.Начало = Данные.ВремяНачала И Эл.Конец = Данные.ВремяОкончания И Эл.Значение = Данные.Распределение И Эл.ЗначенияИзмерений.Получить("Аудитории") = Данные.Аудитория Тогда
				Планировка.Элементы.Удалить(ПланИнд);
			КонецЕсли;
		КонецЦикла;
	Исключение
		ЭтотОбъект.Записать();
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура РаспределенияПередУдалением(Элемент, Отказ)
	Инд = Элементы.Распределения.ТекущаяСтрока;
	Если Инд <> Неопределено Тогда
		РаспределенияПередУдалениемНаСервере(Инд);
	КонецЕсли;
КонецПроцедуры

