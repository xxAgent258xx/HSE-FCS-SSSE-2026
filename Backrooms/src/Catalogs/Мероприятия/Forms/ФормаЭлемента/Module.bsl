//					НовСтрока = Ложь;
						
				// Если изменилось время
				Если (НачалоДня(Эл.Начало) = НачалоДня(Данные.ВремяНачала) ИЛИ НачалоДня(Эл.Конец) = НачалоДня(Данные.ВремяОкончания)) И Эл.Значение = Данные.Распределение И Эл.ЗначенияИзмерений.Получить("Аудитории") = Данные.Аудитория Тогда
					
