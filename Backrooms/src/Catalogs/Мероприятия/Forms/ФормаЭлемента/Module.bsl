//					
//					Парам = Новый Структура();
//					Парам.Вставить("Значение", Данные.Распределение);
//					Парам.Вставить("Текст", Данные.Распределение);
//					Эл.Загрузить(Парам);
//					НовСтрока = Ложь;
//				
