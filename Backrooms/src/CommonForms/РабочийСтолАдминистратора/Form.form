      <horizontalAlign>Center</horizontalAlign>
      <verticalAlign>Center</verticalAlign>
      <behavior>Auto</behavior>
      <representation>Auto</representation>
      <showAsCard>true</showAsCard>
      <showLeftMargin>true</showLeftMargin>
