<?xml version="1.0" encoding="UTF-8"?>
<form:Form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:core="http://g5.1c.ru/v8/dt/mcore" xmlns:form="http://g5.1c.ru/v8/dt/form">
  <items xsi:type="form:FormGroup">
    <name>Основная</name>
    <id>1</id>
    <items xsi:type="form:Button">
      <name>УправлениеОрганизацией</name>
      <id>5</id>
      <visible>true</visible>
      <enabled>true</enabled>
      <userVisible>
        <common>true</common>
      </userVisible>
      <extendedTooltip>
        <name>УправлениеОрганизациейРасширеннаяПодсказка</name>
        <id>6</id>
        <type>Label</type>
        <autoMaxWidth>true</autoMaxWidth>
        <autoMaxHeight>true</autoMaxHeight>
        <extInfo xsi:type="form:LabelDecorationExtInfo">
          <horizontalAlign>Left</horizontalAlign>
        </extInfo>
      </extendedTooltip>
      <type>UsualButton</type>
      <commandName>Form.Command.УправлениеОрганизацией</commandName>
      <buttonImportance>Normal</buttonImportance>
      <representation>Auto</representation>
      <width>50</width>
      <autoMaxWidth>true</autoMaxWidth>
      <height>2</height>
      <autoMaxHeight>true</autoMaxHeight>
      <groupHorizontalAlign>Center</groupHorizontalAlign>
      <groupVerticalAlign>Center</groupVerticalAlign>
      <placementArea>UserCmds</placementArea>
      <backColor xsi:type="core:ColorDef">
        <red>139</red>
        <green>92</green>
        <blue>246</blue>
      </backColor>
      <representationInContextMenu>Auto</representationInContextMenu>
      <cardPictureAndTitleAlign>CenterHorizontallyCenterVertically</cardPictureAndTitleAlign>
      <showAsCard>true</showAsCard>
    </items>
    <items xsi:type="form:Button">
      <name>УправлениеМероприятиями</name>
