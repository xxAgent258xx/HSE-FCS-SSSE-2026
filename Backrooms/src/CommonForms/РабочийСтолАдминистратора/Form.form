    <visible>true</visible>
    <enabled>true</enabled>
    <userVisible>
      <common>true</common>
    </userVisible>
    <title>
      <key>ru</key>
      <value>Основная</value>
    </title>
    <horizontalStretch>true</horizontalStretch>
    <verticalStretch>true</verticalStretch>
    <extendedTooltip>
      <name>ОсновнаяРасширеннаяПодсказка</name>
      <id>2</id>
