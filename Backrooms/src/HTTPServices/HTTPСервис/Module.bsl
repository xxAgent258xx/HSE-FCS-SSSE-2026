Функция ПользовательНайден(СтрокаJSON)Экспорт
	
	 ЧтениеJSON = Новый ЧтениеJSON();
	 ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	 
	 НоменклатураМассив = ПрочитатьJSON(ЧтениеJSON);
	 Для Каждого СтрокаМассива Из НоменклатураМассив Цикл
	 	Логин = Справочники.Пользователи.НайтиПоРеквизиту("Логин", СтрокаМассива.Логин); 
	 	Если Логин.Пустая() Тогда
			СоздатьНоменклатуру(СтрокаМассива);
			Возврат Ложь;
	 	Иначе
	 		Возврат Истина;
	 	КонецЕсли
	 КонецЦикла;

 КонецФункции
 
 Процедура СоздатьНоменклатуру(СтруктураСДанными)
	 
	НоменклатураОбъект = Справочники.Пользователи.СоздатьЭлемент();
	НоменклатураОбъект.Наименование = СтруктураСДанными.Наименование;
	НоменклатураОбъект.Логин = СтруктураСДанными.Логин;
	НоменклатураОбъект.НомерТелефона = СтруктураСДанными.НомерТелефона;
	НоменклатураОбъект.Пароль = СтруктураСДанными.Пароль;
	НоменклатураОбъект.ТипАккаунта = Перечисления.ТипыАккаунтов.Участник;
	
	НоменклатураОбъект.Записать();
	 
 КонецПроцедуры

Функция РегистрацияPOST(Запрос)
	
	СтрокаНоменклатураJSON = Запрос.ПолучитьТелоКакСтроку();
	ПользовательНайден = ПользовательНайден(СтрокаНоменклатураJSON);
	Если ПользовательНайден Тогда
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.УстановитьТелоИзСтроки("Такой пользователь уже существует");
	Иначе
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.УстановитьТелоИзСтроки("Пользователь успешно зарегистрирован");
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

Функция ВходPOST(Запрос)

	СтрокаJSON = Запрос.ПолучитьТелоКакСтроку();
	
	// Читаем массив (как и в регистрации)
	ЧтениеJSON = Новый ЧтениеJSON();
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	МассивДанных = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	Если МассивДанных.Количество() = 0 Тогда
		Ответ = Новый HTTPСервисОтвет(400);
		Ответ.УстановитьТелоИзСтроки("Не переданы данные для входа");
		Возврат Ответ;
	КонецЕсли;
	
	ДанныеВхода = МассивДанных[0];
	Логин = ДанныеВхода.Логин;
	Пароль = ДанныеВхода.Пароль;
	
	// Поиск пользователя по логину
	НайденныйПользователь = Справочники.Пользователи.НайтиПоРеквизиту("Логин", Логин);
	Если НайденныйПользователь.Пустая() Тогда
		Ответ = Новый HTTPСервисОтвет(400);
		Ответ.УстановитьТелоИзСтроки("Пользователь с таким логином не найден");
		Возврат Ответ;
	КонецЕсли;
	
	// Сравнение паролей (предполагаем, что пароль хранится в реквизите "Пароль")
	Если НайденныйПользователь.Пароль <> Пароль Тогда
		Ответ = Новый HTTPСервисОтвет(500);
		Ответ.УстановитьТелоИзСтроки("Неверный пароль");
		Возврат Ответ;
	КонецЕсли;
	
	// Всё верно
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.УстановитьТелоИзСтроки("Вход выполнен успешно");
	Возврат Ответ;
	
КонецФункции


Функция ЛичныеМероприятияGET(Запрос)

    // 1. Получаем параметр login из URL
    Логин = "";
    Попытка
        Логин = Запрос.ПараметрыЗапроса.Получить("login");
    Исключение
        // Если параметр не передан или произошла ошибка
        Логин = "";
    КонецПопытки;

    // 2. Проверяем, что логин передан
    Если ПустаяСтрока(Логин) Тогда
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("Не передан параметр login");
        Возврат Ответ;
    КонецЕсли;

    // 3. Проверяем, существует ли пользователь с таким логином
    Пользователь = Справочники.Пользователи.НайтиПоРеквизиту("Логин", Логин);
    Если Пользователь.Пустая() Тогда
        Ответ = Новый HTTPСервисОтвет(404);
        Ответ.УстановитьТелоИзСтроки("Пользователь не найден");
        Возврат Ответ;
    КонецЕсли;

    // 4. Запрос к справочнику Мероприятия
    ЗапросСУБД = Новый Запрос;
    ЗапросСУБД.Текст =
    "ВЫБРАТЬ
    |	Мероприятия.Наименование КАК Наименование,
    |	Мероприятия.Организация.Наименование КАК ОрганизацияНаименование,
    |	Мероприятия.ГлавныйОрганизатор.Наименование КАК ГлавныйОрганизаторНаименование,
    |	Мероприятия.ЧислоУчастников КАК ЧислоУчастников
    |ИЗ
    |	Справочник.Мероприятия КАК Мероприятия
    |ГДЕ
    |	Мероприятия.СписокУчастников.Участник.Логин = &Логин";

    ЗапросСУБД.УстановитьПараметр("Логин", Логин);

    Результат = ЗапросСУБД.Выполнить();
    Выборка = Результат.Выбрать();

    МассивМероприятий = Новый Массив;

    Пока Выборка.Следующий() Цикл
        СтруктураМероприятия = Новый Структура;
        СтруктураМероприятия.Вставить("Наименование", Выборка.Наименование);
        СтруктураМероприятия.Вставить("ЧислоУчастников", Выборка.ЧислоУчастников);
        СтруктураМероприятия.Вставить("ГлавныйОрганизатор", Выборка.ГлавныйОрганизаторНаименование);
        СтруктураМероприятия.Вставить("Организация", Выборка.ОрганизацияНаименование);

        МассивМероприятий.Добавить(СтруктураМероприятия);
    КонецЦикла;

    // 5. Преобразуем в JSON
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, МассивМероприятий);
    СтрокаJSON = ЗаписьJSON.Закрыть();

    // 6. Формируем успешный ответ
    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON);

    Возврат Ответ;

КонецФункции

Функция ЗаписьНаМероприятиеPOST(Запрос) Экспорт
    
    // 1. Получаем тело запроса как строку
    СтрокаJSON = Запрос.ПолучитьТелоКакСтроку();
    
    // 2. Парсим JSON
    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
    Данные = ПрочитатьJSON(ЧтениеJSON);
    ЧтениеJSON.Закрыть();
    
    // 3. Проверяем наличие обязательных полей
    Если ТипЗнч(Данные) <> Тип("Структура") Тогда
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("Некорректный формат JSON. Ожидается структура с полями 'Код' и 'Логин'.");
        Возврат Ответ;
    КонецЕсли;
    
    КодМероприятия = Неопределено;
    Если Данные.Свойство("Код") Тогда
        КодМероприятия = Данные.Код;
    КонецЕсли;
    
    ЛогинПользователя = Неопределено;
    Если Данные.Свойство("Логин") Тогда
        ЛогинПользователя = Данные.Логин;
    КонецЕсли;
    
    Если КодМероприятия = Неопределено ИЛИ ПустаяСтрока(КодМероприятия) Тогда
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("Не передан код мероприятия.");
        Возврат Ответ;
    КонецЕсли;
    
    Если ЛогинПользователя = Неопределено ИЛИ ПустаяСтрока(ЛогинПользователя) Тогда
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("Не передан логин пользователя.");
        Возврат Ответ;
    КонецЕсли;
    
    // 4. Ищем мероприятие по коду
    МероприятиеСсылка = Справочники.Мероприятия.НайтиПоРеквизиту("Код", КодМероприятия);
    Если МероприятиеСсылка.Пустая() Тогда
        Ответ = Новый HTTPСервисОтвет(404);
        Ответ.УстановитьТелоИзСтроки("Мероприятие с кодом '" + КодМероприятия + "' не найдено.");
        Возврат Ответ;
    КонецЕсли;
    
    // 5. Ищем пользователя по логину
    ПользовательСсылка = Справочники.Пользователи.НайтиПоРеквизиту("Логин", ЛогинПользователя);
    Если ПользовательСсылка.Пустая() Тогда
        Ответ = Новый HTTPСервисОтвет(404);
        Ответ.УстановитьТелоИзСтроки("Пользователь с логином '" + ЛогинПользователя + "' не найден.");
        Возврат Ответ;
    КонецЕсли;
    
    // 6. Получаем объект мероприятия для редактирования
    МероприятиеОбъект = МероприятиеСсылка.ПолучитьОбъект();
    Если МероприятиеОбъект = Неопределено Тогда
        Ответ = Новый HTTPСервисОтвет(500);
        Ответ.УстановитьТелоИзСтроки("Не удалось получить объект мероприятия для редактирования.");
        Возврат Ответ;
    КонецЕсли;
    
    // 7. Проверяем, не зарегистрирован ли уже пользователь
    Для каждого СтрокаТЧ Из МероприятиеОбъект.СписокУчастников Цикл
        Если СтрокаТЧ.Участник = ПользовательСсылка Тогда
            Ответ = Новый HTTPСервисОтвет(409);
            Ответ.УстановитьТелоИзСтроки("Пользователь уже зарегистрирован на это мероприятие.");
            Возврат Ответ;
        КонецЕсли;
    КонецЦикла;
    
    // 8. Проверяем лимит участников (если ЧислоУчастников > 0)
    ТекущееКоличество = МероприятиеОбъект.СписокУчастников.Количество();
    МаксимальноеКоличество = МероприятиеОбъект.ЧислоУчастников;
    
    Если МаксимальноеКоличество > 0 И ТекущееКоличество >= МаксимальноеКоличество Тогда
        Ответ = Новый HTTPСервисОтвет(409);
        Ответ.УстановитьТелоИзСтроки("Достигнуто максимальное количество участников (" + Строка(МаксимальноеКоличество) + ").");
        Возврат Ответ;
    КонецЕсли;
    
    // 9. Добавляем запись в табличную часть
    Попытка
        НоваяСтрока = МероприятиеОбъект.СписокУчастников.Добавить();
        НоваяСтрока.Участник = ПользовательСсылка;
        // Если есть другие реквизиты (например, ДатаРегистрации), можно заполнить
        // НоваяСтрока.ДатаРегистрации = ТекущаяДата();
        
        МероприятиеОбъект.Записать();
    Исключение
        Ответ = Новый HTTPСервисОтвет(500);
        Ответ.УстановитьТелоИзСтроки("Ошибка при записи регистрации: " + ОписаниеОшибки());
        Возврат Ответ;
    КонецПопытки;
    
    // 10. Успешный ответ
    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.УстановитьТелоИзСтроки("Регистрация на мероприятие успешно выполнена.");
    Возврат Ответ;
    
КонецФункции

